@page "/404"
@rendermode InteractiveServer
<div class="container py-5 mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm py-5">
                <div class="card-body">
                    @* Icono representativo *@
                    <div class="mb-4">
                        <i class="bi bi-exclamation-circle text-warning" style="font-size: 4rem;"></i>
                    </div>

                    <h1 class="display-5 fw-bold text-dark mb-3">404</h1>
                    <h4 class="fw-semibold text-secondary mb-4">¡Ups! Página no encontrada</h4>
                    
                    <p class="text-muted mb-5">
                        Lo sentimos, la página que estás buscando no existe o ha sido movida. 
                        Verifica la dirección o intenta volver al inicio.
                    </p>

                    <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                        <button class="btn btn-outline-secondary px-4" @onclick="VolverAtras">
                            <i class="bi bi-arrow-left me-2"></i>Regresar
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="mt-4 text-muted small">
                Ventanilla Única &copy; 2026 - Sistema de Trámites
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = null!;

    private void VolverAtras()
    {
        Nav.NavigateTo("/Solicitudes");
    }
}