@using VentanillaUnica.Generics.GenericDisplayName
@using VentanillaUnica.Services.Solicitud.Enums

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        @* Encabezado con info del Ciudadano *@
        <div class="d-flex align-items-center gap-2 mb-4">
            <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center"
                 style="width:36px;height:36px;">
                <i class="bi bi-file-earmark-text text-white"></i>
            </div>
            <div class="flex-grow-1">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="mb-0 fw-semibold">Seleccionar trámite</h6>
                        <small class="text-muted">
                            <strong>@Ciudadano.PrimerNombre @Ciudadano.PrimerApellido</strong>
                            — @Ciudadano.NumeroDocumento
                        </small>
                    </div>
                    <div style="min-width:160px;">
                        <label class="form-label form-label-sm mb-1">Origen</label>
                        <select class="form-select form-select-sm" @bind="_origen">
                            @foreach (var o in Enum.GetValues<Origen>())
                            {
                                <option value="@o">@o.GetDisplayName()</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        @if (_errorMensaje is not null)
        {
            <div class="alert alert-danger py-2 alert-dismissible">
                <small>@_errorMensaje</small>
                <button class="btn-close btn-sm" @onclick="() => _errorMensaje = null"></button>
            </div>
        }

        <div class="mb-3">
            <label class="form-label form-label-sm">Descripción / motivo</label>
            <textarea class="form-control form-control-sm" @bind="_descripcion" rows="3" maxlength="500"
                      placeholder="Motivo de la solicitud..."></textarea>
            <small class="text-muted">@(_descripcion?.Length ?? 0) / 500</small>
        </div>
        <div class="mb-3">
            <label class="form-label form-label-sm fw-bold">Número de folio</label>
            <input type="text"
                   class="form-control form-control-sm"
                   @bind="_numeroFolio"
                   @oninput="@((ChangeEventArgs e) => _numeroFolio = new string(e.Value?.ToString()?.Where(char.IsDigit).ToArray()))"
                   inputmode="numeric"
                   pattern="[0-0]*"
                   maxlength="12"
                   placeholder="Solo números"/>
        </div>

        <div class="mb-4">
            <div class="row g-3">
                @* Combo 1: Categorías *@
                <div class="col-md-6">
                    <label class="form-label form-label-sm">Categoría</label>
                    <select class="form-select form-select-sm" @onchange="OnTipoFiltroChanged">
                        <option value="-1">— Todas —</option>
                        <option value="0">[ Sin categoría ]</option>
                        @foreach (var cat in Categorias)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>

                @* Combo 2: Trámites *@
                <div class="col-md-6">
                    <label class="form-label form-label-sm">Trámite <span class="text-danger">*</span></label>
                    <select class="form-select form-select-sm" value="@_tramiteId" @onchange="OnTramiteChanged">
                        <option value="0">— Seleccione —</option>
                        @foreach (var t in TramitesFiltrados)
                        {
                            <option value="@t.Id">@t.Name (@t.DiasEstimados días)</option>
                        }
                    </select>
                </div>
            </div>

            @if (_tramiteId != 0)
            {
                var seleccionado = Tramites.FirstOrDefault(t => t.Id == _tramiteId);
                if (seleccionado != null)
                {
                    @if (seleccionado.RequierePlaca.HasValue && seleccionado.RequierePlaca.Value)
                    {
                        <div class="mt-3 p-3 bg-light rounded border-start border-primary border-4">
                            <label class="form-label fw-bold">Placas del vehículo *</label>

                            @for (int i = 0; i < _placas.Count; i++)
                            {
                                var index = i; // Copia local del índice para evitar problemas de clausura en lambdas

                                <div class="input-group mb-2" @key="index">
                                    <input type="text"
                                           class="form-control form-control-sm text-uppercase"
                                           value="@_placas[index]"
                                           @onchange="@((ChangeEventArgs e) => ActualizarPlaca(index, e.Value?.ToString()))"
                                           maxlength="6"
                                           placeholder="Ej: IJV717"/>

                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger"
                                            @onclick="() => RemoverPlaca(index)">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                             fill="currentColor" class="bi bi-trash" viewBox="0 0 16 16">
                                            <path
                                                d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
                                            <path
                                                d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
                                        </svg>
                                    </button>
                                </div>
                            }

                            <button type="button"
                                    class="btn btn-sm btn-outline-primary mt-2"
                                    @onclick="AgregarPlaca">
                                <i class="bi bi-plus-circle"></i> Agregar otra placa
                            </button>

                            <small class="text-muted d-block mt-2">
                                Total: @_placas.Count placa(s)
                            </small>
                            @if (!String.IsNullOrEmpty(_errorMessage))
                            {
                                <small class="text-danger d-block mt-2">
                                    @_errorMessage
                                </small>
                            }
                        </div>
                    }
                }
            }
        </div>

        <div class="d-flex justify-content-between mt-4">
            <button class="btn btn-outline-secondary" @onclick="OnVolver">← Volver</button>
            <button class="btn btn-primary px-4" @onclick="RadicarAsync" disabled="@(_tramiteId == 0 || _cargando)">
                @if (_cargando)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                Radicar solicitud →
            </button>
        </div>
    </div>
</div>