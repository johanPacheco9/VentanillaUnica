@using VentanillaUnica.Generics.GenericDisplayName
@using VentanillaUnica.Models
@using VentanillaUnica.Services.Solicitud
@using VentanillaUnica.Services.Solicitud.Enums
@using VentanillaUnica.Services.Solicitud.Requests
@inject SolicitudManager SolicitudSvc
@rendermode InteractiveServer

<div class="card shadow-sm border-0">
    <div class="card-body p-4">

        <div class="d-flex align-items-center gap-2 mb-4">
            <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center"
                 style="width:36px;height:36px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="white" viewBox="0 0 16 16">
                    <path
                        d="M9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V4.5L9.5 0zm0 1v2A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5z"/>
                </svg>
            </div>
            <div class="flex-grow-1">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="mb-0 fw-semibold">Seleccionar trámite</h6>
                        <small class="text-muted">
                            <strong>
                                @Ciudadano.PrimerNombre
                                @(string.IsNullOrEmpty(Ciudadano.SegundoNombre) ? "" : Ciudadano.SegundoNombre + " ")
                                @Ciudadano.PrimerApellido
                            </strong>
                            — @Ciudadano.NumeroDocumento
                        </small>
                    </div>
                    <div style="min-width:160px;">
                        <label class="form-label form-label-sm mb-1">Origen</label>
                        <select class="form-select form-select-sm" @bind="_origen">
                            @foreach (var o in Enum.GetValues<Origen>())
                            {
                                <option value="@o">@o.GetDisplayName()</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        @if (_errorMensaje is not null)
        {
            <div class="alert alert-danger py-2 alert-dismissible">
                <small>@_errorMensaje</small>
                <button class="btn-close btn-sm" @onclick="() => _errorMensaje = null"></button>
            </div>
        }

        <div class="mb-3">
            <label class="form-label form-label-sm">Descripción / motivo</label>
            <textarea class="form-control form-control-sm"
                      @bind="_descripcion"
                      rows="3"
                      maxlength="500"
                      placeholder="Describa brevemente el motivo de la solicitud..."></textarea>
            <small class="text-muted">@(_descripcion?.Length ?? 0) / 500</small>
        </div>
        <div class="mb-4">
            <label class="form-label form-label-sm">
                Tipo de trámite <span class="text-danger">*</span>
            </label>
            <select class="form-select form-select-sm" 
                    value="@_tramiteId" 
                    @onchange="OnTramiteChanged">
                <option value="0">— Seleccione un trámite —</option>
                @foreach (var t in Tramites)
                {
                    <option value="@t.Id">@t.Nombre (@t.DiasEstimados días hábiles)</option>
                }
            </select>
            @if (_tramiteId != 0)
            {
                var tramite = Tramites.First(t => t.Id == _tramiteId);
                <small class="text-muted mt-1 d-block">
                    Tiempo estimado: <strong>@tramite.DiasEstimados días hábiles</strong>
                    @if (!string.IsNullOrEmpty(tramite.Descripcion))
                    {
                        <span> — @tramite.Descripcion</span>
                    }
                </small>
                
                @if (tramite.TipoTramite?.RequierePlaca == true)
                {
                    <div class="mt-3 p-3 bg-light rounded border-start border-primary border-4">
                        <label class="form-label form-label-sm fw-bold">
                            <i class="bi bi-car-front"></i> Placa del vehículo <span class="text-danger">*</span>
                        </label>
                        <input type="text" 
                               class="form-control form-control-sm text-uppercase" 
                               @bind="_placa" 
                               placeholder="Ej: ABC123" 
                               maxlength="6" />
                        <small class="text-muted">Este trámite requiere identificar un vehículo.</small>
                    </div>
                }
            }
        </div>
       
       
        <div class="d-flex justify-content-between">
            <button class="btn btn-outline-secondary" @onclick="() => OnVolver.InvokeAsync()">← Volver</button>
            <button class="btn btn-primary px-4"
                    @onclick="RadicarAsync"
                    disabled="@(_tramiteId == 0 || _cargando)">
                @if (_cargando)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                    <span>Radicando...</span>
                }
                else
                {
                    <span>Radicar solicitud →</span>
                }
            </button>
        </div>
    </div>
</div>
