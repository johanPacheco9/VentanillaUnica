@using VentanillaUnica.Models
@using VentanillaUnica.Services.Ciudadano
@using VentanillaUnica.Services.Ciudadano.Requests
@inject CiudadanoManager CiudadanoSvc
@rendermode InteractiveServer

<div class="card shadow-sm border-0 mx-auto" style="max-width: 600px;">
    <div class="card-body p-4">

        <div class="d-flex align-items-center gap-2 mb-4">
            <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center" style="width:36px;height:36px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="white" viewBox="0 0 16 16">
                    <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                    <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
                </svg>
            </div>
            <div>
                <h6 class="mb-0 fw-semibold">Identificar ciudadano</h6>
                <small class="text-muted">Ingrese el número de documento</small>
            </div>
        </div>

        @if (_errorMensaje is not null)
        {
            <div class="alert alert-danger alert-dismissible py-2" role="alert">
                <small>@_errorMensaje</small>
                <button type="button" class="btn-close btn-sm" @onclick="() => _errorMensaje = null"></button>
            </div>
        }

        @if (!_buscado)
        {
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398l3.85 3.85a1 1 0 0 0 1.415-1.415l-3.868-3.833zm-5.242 1.156a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z"/>
                    </svg>
                </span>
                <input class="form-control border-start-0 ps-0"
                       @bind="_identificacion"
                       @bind:event="oninput"
                       @onkeydown="OnKeyDown"
                       placeholder="Ej: 1098765432"
                       disabled="@_cargando" />
                <button class="btn btn-primary px-4" @onclick="BuscarAsync"
                        disabled="@(_cargando || string.IsNullOrWhiteSpace(_identificacion))">
                    @if (_cargando)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                        <span>Buscando...</span>
                    }
                    else
                    {
                        <span>Buscar</span>
                    }
                </button>
            </div>
            <small class="text-muted mt-2 d-block">Presione Enter o haga clic en Buscar</small>
        }
        else if (_ciudadanoEncontrado != null)
        {
            <div class="alert alert-success border-0 d-flex align-items-center justify-content-between py-2 mb-0">
                <div class="d-flex align-items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="text-success" viewBox="0 0 16 16">
                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                    </svg>
                    <span>
                        Ciudadano encontrado:
                        <strong>@_ciudadanoEncontrado.PrimerNombre @_ciudadanoEncontrado.PrimerApellido</strong>
                    </span>
                </div>
                <button class="btn btn-sm btn-outline-secondary" @onclick="Reiniciar">Cambiar</button>
            </div>
        }
        else
        {
            <div class="alert alert-warning border-0 py-2 mb-4">
                <small>
                    Cédula <strong>@_identificacion</strong> no registrada.
                    Complete los datos para continuar.
                </small>
            </div>

            <EditForm Model="_form" OnValidSubmit="RegistrarAsync">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-6">
                        <label class="form-label form-label-sm">Primer nombre <span class="text-danger">*</span></label>
                        <InputText class="form-control form-control-sm" @bind-Value="_form.PrimerNombre" placeholder="Juan" />
                        <ValidationMessage For="() => _form.PrimerNombre" />
                    </div>
                    <div class="col-6">
                        <label class="form-label form-label-sm">Segundo nombre</label>
                        <InputText class="form-control form-control-sm" @bind-Value="_form.SegundoNombre" placeholder="Opcional" />
                    </div>
                    <div class="col-6">
                        <label class="form-label form-label-sm">Primer apellido <span class="text-danger">*</span></label>
                        <InputText class="form-control form-control-sm" @bind-Value="_form.PrimerApellido" placeholder="García" />
                        <ValidationMessage For="() => _form.PrimerApellido" />
                    </div>
                    <div class="col-6">
                        <label class="form-label form-label-sm">Segundo apellido</label>
                        <InputText class="form-control form-control-sm" @bind-Value="_form.SegundoApellido" placeholder="Opcional" />
                    </div>
                    <div class="col-6">
                        <label class="form-label form-label-sm">Email</label>
                        <InputText class="form-control form-control-sm" @bind-Value="_form.Email" placeholder="correo@ejemplo.com" />
                        <ValidationMessage For="() => _form.Email" />
                    </div>
                    <div class="col-6">
                        <label class="form-label form-label-sm">Teléfono</label>
                        <InputText class="form-control form-control-sm" @bind-Value="_form.Telefono" placeholder="3001234567" />
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-between">
                    <button type="button" class="btn btn-outline-secondary" @onclick="Reiniciar">
                        ← Volver
                    </button>
                    <button type="submit" class="btn btn-primary px-4" disabled="@_cargando">
                        @if (_cargando)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            <span>Registrando...</span>
                        }
                        else
                        {
                            <span>Registrar y continuar →</span>
                        }
                    </button>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter] public EventCallback<Ciudadano> OnCiudadanoConfirmado { get; set; }

    private string _identificacion = string.Empty;
    private bool   _buscado        = false;
    private bool   _cargando       = false;
    private string? _errorMensaje;

    private Ciudadano?            _ciudadanoEncontrado;
    private RegistrarCiudadanoForm _form = new();

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await BuscarAsync();
    }

    private async Task BuscarAsync()
    {
        if (string.IsNullOrWhiteSpace(_identificacion)) return;

        _cargando     = true;
        _errorMensaje = null;

        var request = new GetCiudadanoByIdRequest { IdNumber = _identificacion };

        _ciudadanoEncontrado = await CiudadanoSvc.GetByIdNumber(request);
        _buscado  = true;
        _cargando = false;

        if (_ciudadanoEncontrado != null)
            await OnCiudadanoConfirmado.InvokeAsync(_ciudadanoEncontrado);
        else
            _form = new RegistrarCiudadanoForm();
    }

    private async Task RegistrarAsync()
    {
        _cargando     = true;
        _errorMensaje = null;

        try
        {
            var request = new RegistrarCiudadanoRequest
            {
                PrimerNombre         = _form.PrimerNombre,
                SegundoNombre        = _form.SegundoNombre,
                PrimerApellido       = _form.PrimerApellido,
                SegundoApellido      = _form.SegundoApellido,
                Email                = _form.Email,
                Telefono             = _form.Telefono,
                NumeroIdentificacion = _identificacion
            };

            _ciudadanoEncontrado = await CiudadanoSvc.RegistrarAsync(request);
            await OnCiudadanoConfirmado.InvokeAsync(_ciudadanoEncontrado);
        }
        catch (InvalidOperationException ex)
        {
            _errorMensaje = ex.Message;
        }
        catch (Exception)
        {
            _errorMensaje = "Ocurrió un error al registrar. Intente nuevamente.";
        }
        finally
        {
            _cargando = false;
            StateHasChanged();
        }
    }

    private void Reiniciar()
    {
        _identificacion      = string.Empty;
        _buscado             = false;
        _errorMensaje        = null;
        _ciudadanoEncontrado = null;
        _form = new();
    }
}