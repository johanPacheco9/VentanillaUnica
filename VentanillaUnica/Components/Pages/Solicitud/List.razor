@page "/admin/solicitudes"
@using VentanillaUnica.Generics.GenericDisplayName
@using VentanillaUnica.Models
@using VentanillaUnica.Services.Enums
@using VentanillaUnica.Services.Solicitud.Enums
@using VentanillaUnica.Services.Solicitud.Requests
@rendermode InteractiveServer

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="fw-semibold mb-0">Solicitudes</h5>
            <small class="text-muted">Gestión y seguimiento de trámites</small>
        </div>
        <a href="/ventanilla" class="btn btn-primary btn-sm">+ Nueva solicitud</a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label form-label-sm">Estado</label>
                    <select class="form-select form-select-sm"
                            @bind="_filtros.Estado"
                            @bind:after="FiltrarAsync">
                        <option value="">Todos</option>
                        @foreach (var estado in Enum.GetValues<EstadoSolicitud>())
                        {
                            <option value="@estado">@estado.GetDisplayName()</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <div class="form-check form-switch mt-3">
                        <input class="form-check-input" type="checkbox"
                               @bind="_filtros.SoloVencidas"
                               @bind:after="FiltrarAsync" />
                        <label class="form-check-label form-label-sm">Solo vencidas</label>
                    </div>
                </div>
                <div class="col-md-2 ms-auto">
                    <button class="btn btn-outline-secondary btn-sm w-100" @onclick="FiltrarAsync">
                        Actualizar
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (_errorMensaje is not null)
    {
        <div class="alert alert-danger py-2"><small>@_errorMensaje</small></div>
    }

    @if (_cargando)
    {
        <div class="text-center py-5">
            <span class="spinner-border text-primary"></span>
            <p class="text-muted mt-2" style="font-size:13px;">Cargando solicitudes...</p>
        </div>
    }
    else if (_solicitudes.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <p class="mb-0">No se encontraron solicitudes.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:13px;">
                    <thead class="table-light">
                        <tr>
                            <th>Radicado</th>
                            <th>Ciudadano</th>
                            <th>Trámite</th>
                            <th>Estado</th>
                            <th>Fecha solicitud</th>
                            <th>Fecha estimada</th>
                            <th>Funcionario</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _solicitudes)
                        {
                            <tr class="@(EsVencida(s) ? "table-danger" : "")">
                                <td class="fw-semibold">@s.NumeroRadicado</td>
                                <td>
                                    @s.CiudadanoNombreCompleto
                                    <br />
                                    <small class="text-muted">@s.CiudadanoNumeroDocumento</small>
                                </td>
                                <td>@s.TramiteNombre</td>
                                <td>
                                    <span class="badge @GetBadgeEstado(s.Estado)">
                                        @s.Estado.GetDisplayName()
                                    </span>
                                </td>
                                <td>@s.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                                <td class="@(EsVencida(s) ? "text-danger fw-semibold" : "")">
                                    @s.FechaEstimadaFin?.ToString("dd/MM/yyyy")
                                </td>
                                <td>
                                    @(s.FuncionarioNombreCompleto is not null
                                        ? $"{s.FuncionarioNombreCompleto}"
                                        : "—")
                                </td>
                                <td>
                                    <a href="/admin/solicitudes/@s.Id" class="btn btn-sm btn-outline-primary">
                                        Ver
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="d-flex justify-content-between align-items-center mt-3">
            <small class="text-muted">Mostrando @_solicitudes.Count resultados</small>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary"
                        @onclick="PaginaAnterior"
                        disabled="@(_filtros.Pagina == 1)">
                    ← Anterior
                </button>
                <span class="btn btn-sm btn-light disabled">@_filtros.Pagina</span>
                <button class="btn btn-sm btn-outline-secondary"
                        @onclick="PaginaSiguiente"
                        disabled="@(_solicitudes.Count < _filtros.TamañoPagina)">
                    Siguiente →
                </button>
            </div>
        </div>
    }
</div>