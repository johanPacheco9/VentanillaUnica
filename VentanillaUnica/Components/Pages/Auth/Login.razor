@page "/"
@using VentanillaUnica.Services.Users.Requests
@inject NavigationManager Nav
@layout Layout.EmptyLayout
@attribute [AllowAnonymous]
@* Quitamos InteractiveServer aquí para que el Form post sea natural del navegador, 
   o lo dejamos si otros componentes lo necesitan, pero el form debe ser HTML puro *@

<div class="login-container d-flex align-items-center justify-content-center">
    <div class="card shadow-lg border-0" style="max-width: 420px; width: 100%; border-radius: 1rem;">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <img src="/Images/logo.png"
                     alt="Dataset Software"
                     style="height:100px; width:auto; object-fit:contain; margin-bottom:1.2rem;">
            </div>

            <form action="api/auth/login" method="post">
                
                <div class="mb-3">
                    <label class="form-label fw-semibold">Usuario o Correo</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope"></i></span>
                        @* El 'name' debe coincidir EXACTO con la propiedad en LoginRequest *@
                        <input name="UserName" type="text" class="form-control border-start-0 bg-light" 
                               placeholder="usuario@ejemplo.com" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Contraseña</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-key"></i></span>
                        <input name="Password" type="password" class="form-control border-start-0 bg-light" 
                               placeholder="••••••••" required />
                    </div>
                </div>

                <div class="d-flex justify-content-between mb-4">
                    <div class="form-check">
                        <input name="RememberMe" type="checkbox" class="form-check-input" id="chkRemember" value="true" />
                        <label class="form-check-label small" for="chkRemember">Recordarme</label>
                    </div>
                    <a href="/recuperar-clave" class="small text-decoration-none">¿Olvidaste tu clave?</a>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                        <span>Iniciar Sesión</span>
                    </button>
                </div>

                @* Manejo de errores vía QueryString (el controlador nos devuelve aquí si falla) *@
                @if (Nav.Uri.Contains("error=true"))
                {
                    <div class="alert alert-danger mt-3 py-2 small text-center border-0">
                        <i class="bi bi-exclamation-circle me-2"></i>Usuario o contraseña incorrectos.
                    </div>
                }
            </form>
        </div>
        <div class="card-footer bg-light border-0 py-3 text-center" style="border-bottom-left-radius: 1rem; border-bottom-right-radius: 1rem;">
            <span class="text-muted small">¿No tienes cuenta? <a href="/registro" class="fw-bold text-decoration-none">Regístrate</a></span>
        </div>
    </div>
</div>

<style>
    .login-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    }
    .input-group-text {
        color: #6c757d;
    }
</style>

