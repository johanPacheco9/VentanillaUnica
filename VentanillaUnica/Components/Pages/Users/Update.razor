@page "/admin/usuarios/editar/{Id:int}"
@using Microsoft.AspNetCore.Components.Authorization
@using VentanillaUnica.Services.Users
@using VentanillaUnica.Services.Users.Requests
@using VentanillaUnica.Models
@attribute [Authorize(Roles = "Admin")]
@layout Layout.MainLayout
@inject UserManager UserSvc
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<div class="container py-4">
    <div class="d-flex align-items-center mb-4">
        <button class="btn btn-link text-decoration-none p-0 me-3" @onclick="GoBack">
            <i class="bi bi-arrow-left fs-4"></i>
        </button>
        <h3 class="fw-bold mb-0">Editar Usuario</h3>
    </div>

    @if (_request == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Cargando datos del usuario...</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0" style="border-radius: 1rem;">
            <div class="card-body p-4 p-md-5">
                <EditForm Model="_request" OnValidSubmit="HandleUpdate">
                    <DataAnnotationsValidator />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Nombre de Usuario</label>
                            <InputText @bind-Value="_request.UserName" class="form-control bg-light" disabled />
                            <div class="form-text">El nombre de usuario no se puede cambiar.</div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Identificación</label>
                            <InputText @bind-Value="_request.IdNumber" class="form-control" />
                            <ValidationMessage For="@(() => _request.IdNumber)" class="text-danger small" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Nombre</label>
                            <InputText @bind-Value="_request.FirstName" class="form-control" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Apellido</label>
                            <InputText @bind-Value="_request.LastName" class="form-control" />
                        </div>

                        <div class="col-md-8 mb-3">
                            <label class="form-label fw-semibold">Correo Electrónico</label>
                            <InputText @bind-Value="_request.Email" class="form-control" />
                            <ValidationMessage For="@(() => _request.Email)" class="text-danger small" />
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Rol</label>
                            <InputSelect @bind-Value="_request.Role" class="form-select">
                                <option value="Admin">Administrador</option>
                                <option value="Funcionario">Funcionario</option>
                                <option value="Ciudadano">Ciudadano</option>
                            </InputSelect>
                        </div>

                        <div class="col-md-12">
                            <hr class="my-4 text-muted" />
                            <div class="alert alert-info border-0 small">
                                <i class="bi bi-info-circle me-2"></i>
                                Deja la contraseña en blanco si no deseas cambiarla.
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Nueva Contraseña</label>
                            <InputText @bind-Value="_request.Password" type="password" class="form-control" placeholder="Opcional" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-light px-4" @onclick="GoBack">Cancelar</button>
                        <button type="submit" class="btn btn-primary px-4 shadow-sm" disabled="@_isProcessing">
                            @if (_isProcessing)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            Actualizar Usuario
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(_message))
                    {
                        <div class="alert @(_isSuccess ? "alert-success" : "alert-danger") mt-3 border-0 small text-center">
                            @_message
                        </div>
                    }
                </EditForm>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    // Usaremos un DTO similar al de creación pero adaptado para Update
    private UpdateUserRequest? _request;
    private bool _isProcessing = false;
    private string? _message;
    private bool _isSuccess = false;

    protected async override Task OnInitializedAsync()
    {
        try 
        {
            // Buscamos el usuario en la DB
            var user = await UserSvc.GetById(Id);
            
            if (user == null)
            {
                Nav.NavigateTo("/admin/usuarios");
                return;
            }

            // Mapeamos los datos del modelo al Request
            _request = new UpdateUserRequest
            {
                Id = user.Id,
                UserName = user.Username,
                FirstName = user.FirstName,
                LastName = user.LastName,
                Email = user.Email,
                IdNumber = user.IdNumber,
                PhoneNumber = user.PhoneNumber,
                Role = user.Role
            };
        }
        catch (Exception)
        {
            _message = "Error al cargar el usuario.";
        }
    }

    private async Task HandleUpdate()
    {
        _isProcessing = true;
        _message = null;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            _request!.ModificadoPor = authState.User.Identity?.Name ?? "Sistema";

            await UserSvc.Update(_request);
            
            _isSuccess = true;
            _message = "Usuario actualizado correctamente.";
            
            await Task.Delay(1500);
            Nav.NavigateTo("/admin/usuarios");
        }
        catch (Exception ex)
        {
            _isSuccess = false;
            _message = ex.Message;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/admin/usuarios");
}