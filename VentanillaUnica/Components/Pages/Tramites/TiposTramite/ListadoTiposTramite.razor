@using Microsoft.EntityFrameworkCore
@using VentanillaUnica.Data
@using VentanillaUnica.Models
@using VentanillaUnica.Services.Tramites
@inject TramitesManager TramitesSvc
@inject AppDbContext DbContext
@rendermode InteractiveServer

<div>
    <div class="d-flex justify-content-end mb-3">
        <button class="btn btn-primary btn-sm" @onclick="() => _mostrarModal = true">
            + Nuevo tipo
        </button>
    </div>

    @if (_cargando)
    {
        <div class="text-center py-5">
            <span class="spinner-border text-primary"></span>
        </div>
    }
    else if (_tipos.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <p class="mb-0">No se encontraron tipos de trámite.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:13px;">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Requiere placa</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in _tipos)
                        {
                            <tr>
                                <td class="fw-semibold">@t.Name</td>
                                <td class="text-muted">@(t.Description ?? "—")</td>
                                <td>
                                    @if (t.RequierePlaca == true)
                                    {
                                        <span class="badge bg-info text-dark">Sí</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">No</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary"
                                            @onclick="() => Editar(t)">
                                        Editar
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (_mostrarModal)
{
    <CreateTipoTramiteModal TipoEditar="_tipoEditar"
                            OnCerrar="CerrarModal"
                            OnGuardado="OnGuardado" />
}

@code {
    private List<TipoTramite> _tipos        = [];
    private bool              _cargando     = true;
    private bool              _mostrarModal = false;
    private TipoTramite?      _tipoEditar;

    protected override async Task OnInitializedAsync() => await CargarAsync();

    private async Task CargarAsync()
    {
        _cargando = true;
        _tipos = await DbContext.TipoTramites
            .AsNoTracking()
            .OrderBy(t => t.Name)
            .ToListAsync();
        _cargando = false;
    }

    private void Editar(TipoTramite tipo)
    {
        _tipoEditar   = tipo;
        _mostrarModal = true;
    }

    private void CerrarModal()
    {
        _mostrarModal = false;
        _tipoEditar   = null;
    }

    private async Task OnGuardado()
    {
        _mostrarModal = false;
        _tipoEditar   = null;
        await CargarAsync();
    }
}