<div class="d-flex flex-column align-items-center gap-1">
    <div class="rounded-circle d-flex align-items-center justify-content-center fw-semibold"
         style="width:28px; height:28px; font-size:12px;
                background:@(Estado == "done" ? "#198754" : Estado == "active" ? "#0d6efd" : "#e9ecef");
                color:@(Estado == "pending" ? "#6c757d" : "white");">
        @if (Estado == "done")
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="white" viewBox="0 0 16 16">
                <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z"/>
            </svg>
        }
        else
        {
            @Numero
        }
    </div>
    <small style="font-size:10px; color:@(Estado == "active" ? "#0d6efd" : "#6c757d");">@Etiqueta</small>
</div>

@code {
    [Parameter] public int    Numero   { get; set; }
    [Parameter] public string Etiqueta { get; set; } = string.Empty;
    [Parameter] public string Estado   { get; set; } = "pending";
}