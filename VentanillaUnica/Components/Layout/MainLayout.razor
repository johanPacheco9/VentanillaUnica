@inherits LayoutComponentBase

<div class="d-flex" style="min-height: 100vh;">

    <!-- Sidebar -->
    <nav class="d-flex flex-column p-0 bg-white border-end" style="width: 240px; min-height: 100vh;">

        <!-- Logo -->
        <div class="px-4 py-3 border-bottom">
            <div class="d-flex align-items-center gap-2">
                <div class="bg-primary rounded d-flex align-items-center justify-content-center" style="width:32px;height:32px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="white" viewBox="0 0 16 16">
                        <path d="M0 1.5A1.5 1.5 0 0 1 1.5 0h13A1.5 1.5 0 0 1 16 1.5v13a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 14.5v-13zM1.5 1a.5.5 0 0 0-.5.5v13a.5.5 0 0 0 .5.5h13a.5.5 0 0 0 .5-.5v-13a.5.5 0 0 0-.5-.5h-13z"/>
                        <path d="M3 4.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zm0 3a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zm0 3a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5z"/>
                    </svg>
                </div>
                <div>
                    <p class="mb-0 fw-semibold text-dark" style="font-size:13px; line-height:1.2;">Dataset Software</p>
                    <p class="mb-0 text-muted" style="font-size:10px;">Ventanilla Única</p>
                </div>
            </div>
        </div>

        <!-- Nav -->
        <div class="flex-grow-1 px-3 py-3">
            <p class="text-uppercase text-muted mb-2 px-2" style="font-size:10px; letter-spacing:.08em;">Principal</p>

            <NavLink class="nav-item-link" href="/ventanilla" Match="NavLinkMatch.All">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 1a2.5 2.5 0 0 1 2.5 2.5V4h-5v-.5A2.5 2.5 0 0 1 8 1zm3.5 3v-.5a3.5 3.5 0 1 0-7 0V4H1v10h14V4h-3.5zM2 5h12v8H2V5z"/>
                </svg>
                <span>Ventanilla</span>
            </NavLink>

            <p class="text-uppercase text-muted mb-2 mt-3 px-2" style="font-size:10px; letter-spacing:.08em;">Administración</p>

            <NavLink class="nav-item-link" href="/admin/solicitudes">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M14.5 3a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h13zm-13-1A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h13a1.5 1.5 0 0 0 1.5-1.5v-9A1.5 1.5 0 0 0 14.5 2h-13z"/>
                    <path d="M3 5.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zM3 8a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9A.5.5 0 0 1 3 8zm0 2.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5z"/>
                </svg>
                <span>Solicitudes</span>
            </NavLink>

            <NavLink class="nav-item-link" href="/admin/funcionarios">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                    <path fill-rule="evenodd" d="M5.216 14A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216z"/>
                    <path d="M4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z"/>
                </svg>
                <span>Funcionarios</span>
            </NavLink>

            <NavLink class="nav-item-link" href="/admin/tramites">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V4.5L9.5 0zm0 1v2A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5z"/>
                </svg>
                <span>Trámites</span>
            </NavLink>

            <NavLink class="nav-item-link" href="/admin/reportes">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M4 11H2v3h2v-3zm5-4H7v7h2V7zm5-5v12h-2V2h2zm-2-1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1h-2zM6 7a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V7zm-5 4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1v-3z"/>
                </svg>
                <span>Reportes</span>
            </NavLink>
        </div>

        <!-- Footer del sidebar -->
        <div class="px-4 py-3 border-top">
            <p class="mb-0 text-muted" style="font-size:11px;">Dataset Software © @DateTime.Now.Year</p>
        </div>
    </nav>

    <!-- Contenido principal -->
    <div class="flex-grow-1 d-flex flex-column bg-light">

        <!-- Topbar -->
        <header class="bg-white border-bottom px-4 d-flex align-items-center justify-content-between" style="height:56px;">
            <div>
                <h6 class="mb-0 fw-semibold text-dark" style="font-size:14px;">
                    Sistema de Gestión — Ventanilla Única
                </h6>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="badge bg-success-subtle text-success border border-success-subtle" style="font-size:11px;">
                    En línea
                </span>
                <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center text-white"
                     style="width:32px;height:32px;font-size:12px;font-weight:600;">
                    AD
                </div>
            </div>
        </header>

        <!-- Página -->
        <main class="flex-grow-1 p-4">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet
     style="display:none; position:fixed; bottom:1rem; right:1rem; z-index:9999;
            background:white; border:1px solid #dee2e6; border-radius:8px;
            padding:.75rem 1rem; box-shadow:0 4px 12px rgba(0,0,0,.1); font-size:13px;">
    Ocurrió un error inesperado.
    <a href="." class="ms-2 text-primary">Recargar</a>
</div>

<style>
    .nav-item-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        border-radius: 6px;
        color: #6c757d;
        text-decoration: none;
        font-size: 13px;
        margin-bottom: 2px;
        transition: background .15s, color .15s;
    }

    .nav-item-link:hover {
        background: #f8f9fa;
        color: #212529;
    }

    .nav-item-link.active {
        background: #e7f1ff;
        color: #0d6efd;
        font-weight: 500;
    }
</style>